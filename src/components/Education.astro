---
const education = [
	{
		school: 'University of Southern California — Viterbi',
		degree: 'MS, Computer Science (Intelligent Robotics)',
		period: 'Expected Dec 2026',
	},
	{
		school: 'Carnegie Mellon University',
		degree: 'BS, Physics/Astrophysics · Minor in Computer Science',
		period: 'May 2024',
	},
];
---

<section id="education" aria-labelledby="education-title">
	<h2 id="education-title" class="section-title">
		<span class="prompt">~/</span>education
	</h2>
	<ul class="entry-list">
		{
			education.map((item) => (
				<li class="entry">
					<div class="entry-head">
						<h3 class="entry-title">{item.school}</h3>
						<span class="entry-period">{item.period}</span>
					</div>
					<p class="entry-sub">{item.degree}</p>
				</li>
			))
		}
	</ul>
</section>

<style>
	.entry-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.5rem;
	}

	.entry-head {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.25rem 1rem;
	}

	.entry-title {
		font-size: 1.05rem;
		margin: 0;
		color: var(--fg);
	}

	.entry-period {
		color: var(--fg-muted);
		font-size: 0.85rem;
		white-space: nowrap;
	}

	.entry-sub {
		margin: 0.35rem 0 0;
		color: var(--accent);
		font-size: 0.95rem;
	}
</style>
